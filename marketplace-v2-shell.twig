{% extends "portal.layouts.main" %}
{% block content %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/pbabakhanian/serppro-marketplace@main/marketplace-v2.css">

<div id="mp2">

  <!-- Header -->
  <div class="mp2-hdr">
    <div>
      <h1>Publisher Marketplace</h1>
      <div class="mp2-hdr-sub">Private inventory &middot; 9,000+ vetted sites &middot; Guaranteed placements</div>
    </div>
    <div class="mp2-hdr-right">
      <div class="mp2-hdr-stats">
        <div class="mp2-stat">
          <div class="mp2-stat-val" id="mp2-cnt-loaded">0</div>
          <div class="mp2-stat-lbl">Sites loaded</div>
        </div>
        <div class="mp2-stat">
          <div class="mp2-stat-val" id="mp2-cnt-match">0</div>
          <div class="mp2-stat-lbl">Matching</div>
        </div>
      </div>
      <button id="mp2-hdr-cart">Cart <span id="mp2-hdr-cart-badge"></span></button>
    </div>
  </div>

  <!-- Progress -->
  <div class="mp2-progress" id="mp2-progress">
    <div class="mp2-progress-fill" id="mp2-prog-fill"></div>
  </div>

  <!-- Filters -->
  <div class="mp2-filters" id="mp2-filters">

    <!-- Row 1 -->
    <div class="mp2-filter-row">
      <div class="mp2-fg" style="flex:1;min-width:160px;max-width:220px;">
        <div class="mp2-flabel">Search Domain</div>
        <input class="mp2-input" id="mp2-q" type="search" placeholder="e.g. healthline.com" style="width:100%">
      </div>
      <div class="mp2-fg">
        <div class="mp2-flabel">DR Range</div>
        <div class="mp2-rpair">
          <input class="mp2-input" id="mp2-dr0" type="number" placeholder="0" min="0" max="100">
          <span class="mp2-rsep">to</span>
          <input class="mp2-input" id="mp2-dr1" type="number" placeholder="100" min="0" max="100">
        </div>
      </div>
      <div class="mp2-fg">
        <div class="mp2-flabel">Traffic</div>
        <div class="mp2-rpair">
          <input class="mp2-input" id="mp2-tr0" type="number" placeholder="0" min="0" style="width:76px">
          <span class="mp2-rsep">to</span>
          <input class="mp2-input" id="mp2-tr1" type="number" placeholder="Max" min="0" style="width:76px">
        </div>
      </div>
      <div class="mp2-fg">
        <div class="mp2-flabel">Price ($)</div>
        <div class="mp2-rpair">
          <input class="mp2-input" id="mp2-pr0" type="number" placeholder="0" min="0" style="width:70px">
          <span class="mp2-rsep">to</span>
          <input class="mp2-input" id="mp2-pr1" type="number" placeholder="Max" min="0" style="width:70px">
        </div>
      </div>
      <div class="mp2-fg" style="flex:1;min-width:200px;">
        <div class="mp2-flabel">Niches / Topics <small>(Enter or , to add tag)</small></div>
        <div class="mp2-topic-wrap" onclick="document.getElementById('mp2-topics').focus()">
          <div id="mp2-tag-pills"></div>
          <input id="mp2-topics" type="text" placeholder="health, finance, tech...">
        </div>
      </div>
    </div>

    <!-- Row 2 -->
    <div class="mp2-filter-row">
      <div class="mp2-fg">
        <div class="mp2-flabel">Do-Follow</div>
        <select class="mp2-select" id="mp2-df">
          <option value="">All</option>
          <option value="Yes">Yes only</option>
          <option value="No">No only</option>
        </select>
      </div>
      <div class="mp2-fg">
        <div class="mp2-flabel">Language</div>
        <select class="mp2-select" id="mp2-lang">
          <option value="">All Languages</option>
          <option>English</option><option>German</option><option>French</option><option>Spanish</option>
          <option>Italian</option><option>Dutch</option><option>Polish</option><option>Portuguese</option>
          <option>Russian</option><option>Swedish</option><option>Norwegian</option><option>Danish</option>
          <option>Finnish</option><option>Greek</option><option>Romanian</option><option>Turkish</option>
          <option>Japanese</option><option>Chinese</option><option>Korean</option><option>Arabic</option>
          <option>Indonesian</option><option>Vietnamese</option><option>Ukrainian</option>
        </select>
      </div>
      <div class="mp2-fg">
        <div class="mp2-flabel">Country</div>
        <select class="mp2-select" id="mp2-country">
          <option value="">All Countries</option>
          <option>United States</option><option>United Kingdom</option><option>Australia</option>
          <option>Canada</option><option>Germany</option><option>France</option><option>Spain</option>
          <option>Italy</option><option>Netherlands</option><option>Poland</option><option>Brazil</option>
          <option>Russia</option><option>Sweden</option><option>Norway</option><option>Denmark</option>
          <option>Finland</option><option>Greece</option><option>Romania</option><option>Turkey</option>
          <option>Japan</option><option>China</option><option>South Korea</option><option>India</option>
          <option>South Africa</option><option>Nigeria</option><option>Singapore</option>
        </select>
      </div>
      <div class="mp2-fg">
        <div class="mp2-flabel">Sensitive Niches</div>
        <div class="mp2-trow">
          <label class="mp2-tog">
            <input type="checkbox" id="mp2-hide-sens">
            <span class="mp2-tog-track"></span>
          </label>
          <span class="mp2-tlbl">Hide adult and gambling</span>
        </div>
      </div>
      <div class="mp2-fg" style="margin-left:auto;">
        <div class="mp2-flabel">&nbsp;</div>
        <button class="mp2-clear-btn" id="mp2-clear">Clear all filters</button>
      </div>
    </div>

  </div>

  <!-- Presets -->
  <div class="mp2-presets-row">
    <span class="mp2-presets-lbl">Saved filters:</span>
    <div id="mp2-preset-list"></div>
    <button class="mp2-save-btn" id="mp2-save-preset">+ Save current</button>
  </div>

  <!-- Table controls -->
  <div class="mp2-tcontrols">
    <div class="mp2-rcount">Showing <b id="mp2-from">0</b> to <b id="mp2-to">0</b> of <b id="mp2-tot">0</b> sites</div>
    <div class="mp2-tright">
      <select class="mp2-rpp" id="mp2-rpp">
        <option value="25">25 per page</option>
        <option value="50">50 per page</option>
        <option value="100">100 per page</option>
      </select>
      <div id="mp2-colwrap">
        <button class="mp2-colbtn" id="mp2-colbtn">Columns</button>
        <div class="mp2-colpanel" id="mp2-colpanel">
          <label><input type="checkbox" data-col="dr" checked> DR</label>
          <label><input type="checkbox" data-col="da" checked> DA</label>
          <label><input type="checkbox" data-col="traffic" checked> Traffic + Trend</label>
          <label><input type="checkbox" data-col="spark" checked> Sparkline</label>
          <label><input type="checkbox" data-col="country" checked> Country</label>
          <label><input type="checkbox" data-col="lang" checked> Language</label>
          <label><input type="checkbox" data-col="topics" checked> Topics</label>
          <label><input type="checkbox" data-col="df" checked> Do-Follow</label>
          <label><input type="checkbox" data-col="price" checked> Price</label>
        </div>
      </div>
    </div>
  </div>

  <!-- Table -->
  <div class="mp2-twrap">
    <table>
      <thead>
        <tr id="mp2-head">
          <th class="mp2-nosort" style="width:46px;"></th>
          <th data-sort="name">Domain <span class="mp2-sico">updown</span></th>
          <th data-sort="dr"      class="c-dr">DR <span class="mp2-sico">updown</span></th>
          <th data-sort="da"      class="c-da">DA <span class="mp2-sico">updown</span></th>
          <th data-sort="tfc"     class="c-traffic">Traffic / Trend <span class="mp2-sico">updown</span></th>
          <th class="mp2-nosort   c-spark">Chart</th>
          <th data-sort="country" class="c-country">Country <span class="mp2-sico">updown</span></th>
          <th data-sort="lang"    class="c-lang">Language <span class="mp2-sico">updown</span></th>
          <th class="mp2-nosort   c-topics">Topics</th>
          <th data-sort="df"      class="c-df">DF <span class="mp2-sico">updown</span></th>
          <th data-sort="price"   class="c-price mp2-sorted">Price <span class="mp2-sico">down</span></th>
          <th class="mp2-nosort" style="width:90px;"></th>
        </tr>
      </thead>
      <tbody id="mp2-body">
        <tr><td colspan="12" class="mp2-empty">
          <div class="mp2-empty-ico">&#x23F3;</div>
          <div class="mp2-empty-txt">Loading publisher inventory...</div>
        </td></tr>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div class="mp2-pager" id="mp2-pager"></div>

  <!-- AI Link Matcher -->
  <div class="mp2-matcher-section">
    <div class="mp2-matcher-hdr">
      <span class="mp2-matcher-badge">AI Powered</span>
      <div class="mp2-matcher-title">AI Link Matcher</div>
    </div>
    <div class="mp2-matcher-sub">Paste your URL and Claude will analyze your site's topic, industry, and authority profile -- then instantly match you with the most relevant publishers from our full inventory of 9,000+ sites.</div>
    <div class="mp2-matcher-input-row">
      <input class="mp2-matcher-inp" id="mp2-matcher-url" type="url" placeholder="https://yoursite.com/page-you-want-links-to">
      <button class="mp2-matcher-btn" id="mp2-matcher-btn">Find Matching Sites</button>
    </div>
    <div id="mp2-matcher-out"></div>
  </div>

</div>

<!-- Floating cart button -->
<button id="mp2-float-cart" title="Your cart">
  Cart
  <span id="mp2-cart-badge"></span>
</button>

<!-- Cart slide panel -->
<div id="mp2-cart-wrap">
  <div class="mp2-cart-hdr">
    <div class="mp2-cart-hdr-title">Your Cart</div>
    <div class="mp2-cart-hdr-sub">Sites added this session</div>
  </div>
  <div id="mp2-cart-panel"></div>
</div>

<script>var MP2_CART = "{{ route('portal.cart.items.store') }}";</script>
<script src="https://cdn.jsdelivr.net/gh/pbabakhanian/serppro-marketplace@main/marketplace-v2.js"></script>

{% endblock %}
